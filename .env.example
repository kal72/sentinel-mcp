# ─── Default AI Provider ─────────────────────────────────────────────────────
# Options: ollama | claude | openai | gemini
DEFAULT_PROVIDER=ollama

# ─── Ollama (Local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-2.0-flash

# ─── Target API ───────────────────────────────────────────────────────────────
TARGET_API_BASE_URL=http://localhost:3000
TARGET_API_TOKEN=your-bearer-token-here

# ─── Report Output ────────────────────────────────────────────────────────────
REPORTS_DIR=./reports
